<?xml version="1.0" encoding="utf-8"?>
<!--
  Relay mark: arched bridge with circular terminals.
  Teal (#00DFC0) → blue (#2E8CFF). No black border — background is @color/ic_launcher_background.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Arch stroke (slightly thinner than terminal nodes) -->
    <path
        android:pathData="M32,70 A22,22 0 0 1 76,70"
        android:fillColor="#00000000"
        android:strokeWidth="12"
        android:strokeLineCap="butt"
        android:strokeLineJoin="round">
        <aapt:attr name="android:strokeColor">
            <gradient
                android:type="linear"
                android:startX="32"
                android:startY="70"
                android:endX="76"
                android:endY="70">
                <item
                    android:offset="0"
                    android:color="#00DFC0" />
                <item
                    android:offset="0.5"
                    android:color="#1AB8E8" />
                <item
                    android:offset="1"
                    android:color="#2E8CFF" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Left terminal node -->
    <path
        android:fillColor="#00DFC0"
        android:pathData="M32,70m-8,0a8,8 0,1 1,16,0a8,8 0,1 1,-16,0" />

    <!-- Right terminal node -->
    <path
        android:fillColor="#2E8CFF"
        android:pathData="M76,70m-8,0a8,8 0,1 1,16,0a8,8 0,1 1,-16,0" />
</vector>
